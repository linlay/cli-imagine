name = 'poe'

[endpoint]
base_url = 'https://api.poe.com/v1'
proxy_url = 'http://127.0.0.1:8001'

[auth]
api_key = ''
api_key_env = 'POE_API_KEY'
api_key_file = ''

[[models]]
name = 'GPT-Image-1'

[models.capabilities]
[models.capabilities.generate]
input_schema = 'schemas/poe/GPT-Image-1.generate.json'

[models.capabilities.generate.request]
kind = 'chat_completions'
size_mode = 'ratio_or_pixel'
aspect_field = 'aspect'
image_size_field = ''

[models.capabilities.generate.response]
default_format = 'url'
allowed_formats = []

[models.capabilities.generate.response.parser_by_format]
url = 'message_content_image'

[[models]]
name = 'gpt-image-1.5'

[models.capabilities]
[models.capabilities.generate]
input_schema = 'schemas/poe/gpt-image-1-5.generate.json'

[models.capabilities.generate.request]
kind = 'chat_completions'
size_mode = 'ratio'
aspect_field = 'aspect'
image_size_field = ''

[models.capabilities.generate.request.default_arguments]
useMask = true

[models.capabilities.generate.response]
default_format = 'url'
allowed_formats = []

[models.capabilities.generate.response.parser_by_format]
url = 'message_content_image'

[[models]]
name = 'grok-imagine-image'

[models.capabilities]
[models.capabilities.generate]
input_schema = 'schemas/poe/grok-imagine-image.generate.json'

[models.capabilities.generate.request]
kind = 'chat_completions'
size_mode = 'ratio'
aspect_field = 'aspect'
image_size_field = ''

[models.capabilities.generate.response]
default_format = 'url'
allowed_formats = []

[models.capabilities.generate.response.parser_by_format]
url = 'message_content_image'

[[models]]
name = 'nano-banana-pro'

[models.capabilities]
[models.capabilities.generate]
input_schema = 'schemas/poe/nano-banana-pro.generate.json'

[models.capabilities.generate.request]
kind = 'chat_completions'
size_mode = 'ratio'
aspect_field = 'aspect_ratio'
image_size_field = 'image_size'

[models.capabilities.generate.request.default_arguments]
imageOnly = true
webSearch = true

[models.capabilities.generate.response]
default_format = 'url'
allowed_formats = []

[models.capabilities.generate.response.parser_by_format]
url = 'message_content_image'

[[models]]
name = 'seedream-5.0-lite'

[models.capabilities]
[models.capabilities.generate]
input_schema = 'schemas/poe/seedream-5-0-lite.generate.json'

[models.capabilities.generate.request]
kind = 'chat_completions'
size_mode = 'ratio'
aspect_field = 'aspect'
image_size_field = ''

[models.capabilities.generate.response]
default_format = 'url'
allowed_formats = []

[models.capabilities.generate.response.parser_by_format]
url = 'message_content_image'
